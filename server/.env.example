# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/notes-app

# Server Configuration
PORT=5000
NODE_ENV=development

# JWT Secret (must not be empty in production)
# Set a secure, unpredictable string. Missing this will fall back to a weak default
# and you'll see a warning on startup.
JWT_SECRET=your_super_secret_jwt_key_change_in_production_12345

# Cors
CORS_ORIGIN=http://localhost:5173

# After filling out this file, use the seeding script to add demo data:
#   cd server && npm run seed
# Seed will clear existing users/notes/logs and insert sample records.
